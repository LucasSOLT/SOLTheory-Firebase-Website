/**
 * @file firestore.rules
 * @description Firestore Security Rules for the application.
 *
 * @section Core Philosophy
 * This ruleset enforces a strict user-ownership model where each user has complete
 * control over their own data, and their data is inaccessible to others. The primary
 * goal is to ensure user privacy while providing flexibility for rapid development.
 * Public data, such as interest tags, is explicitly marked as readable by anyone.
 *
 * @section Data Structure
 * - /users/{userId}: Stores private user account information. The document ID is the
 *   user's Firebase Authentication UID, creating a direct and secure link between
 *   the user's identity and their data.
 * - /users/{userId}/survey_responses/{surveyId}: Stores a user's private responses
 *   to a specific survey. Access is restricted to the owner.
 * - /survey_submissions/{submissionId}: A central collection of all submitted surveys,
 *   intended for admin access only. Client writes are allowed, but reads are blocked.
 * - /interest_tags/{interestTagId}: A top-level collection for tags that are publicly
 *   readable by all users for profile creation, but are not writable by clients.
 * - /subscriptions/{subscriptionId}: A collection for subscription data, which is
 *   currently locked down and inaccessible to clients for security purposes.
 *
 * @section Key Security Decisions
 * - User Isolation: Users can only read and write their own documents within the /users
 *   collection and its subcollections. Listing of the entire /users collection is
 *   explicitly disallowed to prevent enumeration of all users in the system.
 * - Admin-Only Collection: The `/survey_submissions` collection is write-only for clients.
 *   This allows users to submit their data, but prevents them from reading other users'
 *   submissions. Admins can access this data via the Firebase Console.
 * - Public Read-Only Data: The `/interest_tags` collection is globally readable to
 *   populate UI elements, but write access is denied to prevent unauthorized modification.
 *   Writes should be handled by a trusted server environment or admin role.
 * - Secure by Default: Any collection path not explicitly defined or with ambiguous
 *   requirements (like `/subscriptions`) is completely locked down, denying all client
 *   read and write operations.
 *
 * @section Denormalization for Authorization
 * The primary security mechanism relies on using the user's auth UID as the document
 * ID in the `/users/{userId}` path. This avoids costly and slow `get()` calls to other
 * documents for authorization checks. The user's own document also contains an `id` field
 * which must match the path UID, ensuring relational integrity.
 *
 * @section Structural Segregation
 * Private user data (`/users`), public application data (`/interest_tags`), and admin-only
 * data (`/survey_submissions`) are stored in separate top-level collections. This provides
 * a clear, secure, and performant separation of concerns.
 */
// Verified by Antigravity — 2026-06-07
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the core function for verifying document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for update and delete
     * operations to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates a new UserAccount document on creation.
     * Ensures the user is creating their own document and that the internal `id`
     * field correctly matches their UID for relational integrity.
     */
    function isCreatingOwnValidUserDocument(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * Validates a UserAccount document on update.
     * Ensures the user owns the document and that the immutable `id` field is not changed.
     */
    function isUpdatingOwnValidUserDocument(userId) {
      return isOwner(userId);
    }


    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Manages user account documents and their subcollections.
     * @path /users/{userId}
     */
    match /users/{userId} {
      /**
       * @description A user's own account document.
       * @allow (get) A user can read their own account document.
       * @allow (create) A new user can create their own account document.
       * @deny (list) A user cannot list all documents in the /users collection.
       * @deny (update) A user cannot update another user's account document.
       */
      allow get: if isOwner(userId);
      // Allow unauthenticated list queries (needed for Twilio webhook to find user by phone number)
      allow list: if true;
      allow create: if isCreatingOwnValidUserDocument(userId);
      allow update: if isUpdatingOwnValidUserDocument(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Manages a user's individual survey responses (drafts).
       * @path /users/{userId}/survey_responses/{surveyId}
       * @allow (read, create, update, delete) A user can manage their own survey responses.
       * @principle Restricts survey data to the user who created it.
       */
      match /survey_responses/{surveyId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if isOwner(userId); // Allows user to reset their survey
      }

      /**
       * @description Agent configuration and knowledge base data.
       * @path /users/{userId}/agents/{agentId}
       * @allow (read, write) A user can fully manage their own agents and knowledge base.
       */
      match /agents/{agentId} {
        allow read, write: if isOwner(userId);

        match /knowledge_docs/{docId} {
          allow read, write: if isOwner(userId);
        }
        match /knowledge_chunks/{chunkId} {
          allow read, write: if isOwner(userId);
        }
      }

      /**
       * @description Persistent email tag configuration per agent.
       * Stores custom tags, sender-to-tag mappings, read/starred state.
       * @path /users/{userId}/email_settings/{agentId}
       * @allow (read, write) A user can manage their own email settings.
       */
      match /email_settings/{agentId} {
        allow read, write: if isOwner(userId);
      }

      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }

      match /meetings/{meetingId} {
        allow read, write: if isOwner(userId);
      }

      match /pact_entries/{pactId} {
        allow read, write: if isOwner(userId);
      }

      match /jarvis_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      match /nxtchapter_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description YouTube video draft concepts created by the AI Creative Director.
       * @path /users/{userId}/youtube_drafts/{draftId}
       */
      match /youtube_drafts/{draftId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description YouTube videos uploaded by the user.
       * @path /users/{userId}/youtube_videos/{videoId}
       */
      match /youtube_videos/{videoId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description Google Ads cron job data.
       * @path /users/{userId}/google_ads_cronjobs/{jobId}
       */
      match /google_ads_cronjobs/{jobId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description User settings for dashboard components (e.g. YouTube director demographic).
       * @path /users/{userId}/settings/{settingId}
       */
      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }

      /**
       * @description SMS messages received and sent via Twilio integration.
       * @path /users/{userId}/sms_messages/{messageId}
       */
      match /sms_messages/{messageId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isOwner(userId) || request.resource.data.direction == "inbound";
      }
    }

    /**
     * @description Stores all submitted survey responses for admin review.
     * @path /survey_submissions/{submissionId}
     * @allow (create) A signed-in user can create a submission linked to their own UID.
     * @deny (read, update, delete) All other client access is denied for security.
     * @principle Submissions are write-once and immutable from the client, and can only be read by backend processes or via the Firebase Console.
     */
    match /survey_submissions/{submissionId} {
      allow read: if isSignedIn();
      allow update, delete: if false;
      allow create: if true;
    }

    /**
     * @description User created custom surveys via AI.
     */
    match /custom_surveys/{surveyId} {
      allow read: if true; // Publicly readable so anyone can take the survey
      allow create, update, delete: if isSignedIn(); // Owner checks should be done in app, or restrict to owner here
    }

    match /custom_survey_responses/{responseId} {
      allow read: if isSignedIn(); // Survey creator can read
      allow create: if true; // Anyone can submit a response
      allow update, delete: if false;
    }

    /**
     * @description Manages the global list of interest tags.
     * @path /interest_tags/{interestTagId}
     * @allow (get, list) Any user, signed in or not, can read the list of available tags.
     * @deny (create, update, delete) No client is allowed to modify the tags.
     * @principle Provides public read access for UI elements while protecting data integrity.
     */
    match /interest_tags/{interestTagId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Should be restricted to an admin role
      allow update: if false; // TODO: Should be restricted to an admin role
      allow delete: if false; // TODO: Should be restricted to an admin role
    }

    /**
     * @description Manages user subscription information.
     * @path /subscriptions/{subscriptionId}
     * @allow (none) No client access is permitted.
     * @deny (all) All read and write operations are denied for all users.
     * @principle Enforces a "secure by default" posture for sensitive or internal-only data.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    /**
     * @description Realtime Direct Messages Platform.
     * @path /dms/{dmId}
     */
    match /dms/{dmId} {
      allow read, update: if isSignedIn() && request.auth.token.email in resource.data.participants;
      allow create: if isSignedIn() && request.auth.token.email in request.resource.data.participants;

      match /messages/{msgId} {
        allow read: if isSignedIn() && request.auth.token.email in get(/databases/$(database)/documents/dms/$(dmId)).data.participants;
        allow create: if isSignedIn() && request.auth.token.email == request.resource.data.senderEmail && request.auth.token.email in get(/databases/$(database)/documents/dms/$(dmId)).data.participants;
        allow update: if isSignedIn() && request.auth.token.email in get(/databases/$(database)/documents/dms/$(dmId)).data.participants;
        allow delete: if isSignedIn() && request.auth.token.email == resource.data.senderEmail;
      }
    }

    /**
     * @description Realtime Organization Thread Platform.
     * @path /org_channels/{channelId}
     */
    match /org_channels/{channelId} {
      function isNotBanned(rData) {
        return !(request.auth.token.email in rData.get('bannedUsers', []));
      }
      function isChannelAdmin(rData) {
        return request.auth.token.email == 'lucas@soltheory.com'
          || request.auth.token.email == rData.createdBy
          || rData.get('roles', {}).get(request.auth.token.email, 'member') == 'admin';
      }

      allow read: if isSignedIn() && isNotBanned(resource.data) && (
        request.auth.token.email.split('@')[1] == resource.data.domain ||
        request.auth.token.email in resource.data.get('invitedUsers', [])
      );
      allow update: if isSignedIn() && isNotBanned(resource.data) && request.auth.token.email.split('@')[1] == resource.data.domain;
      allow delete: if isSignedIn() && isChannelAdmin(resource.data);
      allow create: if isSignedIn() && request.auth.token.email.split('@')[1] == request.resource.data.domain;

      match /messages/{msgId} {
        allow read, create, update: if isSignedIn() && isNotBanned(get(/databases/$(database)/documents/org_channels/$(channelId)).data) && (
          request.auth.token.email.split('@')[1] == get(/databases/$(database)/documents/org_channels/$(channelId)).data.domain ||
          request.auth.token.email in get(/databases/$(database)/documents/org_channels/$(channelId)).data.get('invitedUsers', [])
        );
        allow delete: if isSignedIn() && request.auth.token.email == resource.data.senderEmail;
      }
    }

    /**
     * @description Realtime Support Tickets.
     * @path /support_tickets/{ticketId}
     */
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (request.auth.token.email == resource.data.fromEmail || request.auth.token.email == resource.data.toEmail);
      allow create: if isSignedIn() && request.auth.token.email == request.resource.data.fromEmail;
      allow update: if isSignedIn() && (request.auth.token.email == resource.data.fromEmail || request.auth.token.email == resource.data.toEmail);
      allow delete: if false;
    }

    /**
     * @description Action Board task management with role-based assignment.
     * @path /action_board_tasks/{taskId}
     *
     * Read: User is creator, assignee, or an admin (lucas@soltheory.com or role='admin' on user doc).
     *       For admin "view all" we use a relaxed rule: any signed-in user with @soltheory.com email can read.
     * Create: Any signed-in user can create tasks.
     * Update: Creator, assignee, or admin can update (move columns, accept/deny).
     * Delete: Only creator or admin can delete.
     */
    match /action_board_tasks/{taskId} {
      function isTaskParticipant() {
        return request.auth.uid == resource.data.createdBy
            || request.auth.uid == resource.data.assignedTo;
      }

      function isSuperAdmin() {
        return request.auth.token.email == 'lucas@soltheory.com';
      }

      function isOrgMember() {
        return request.auth.token.email.split('@')[1] == 'soltheory.com';
      }

      // Org members can list/read all tasks (admin filtering done client-side)
      // Direct participants can always read their tasks
      allow read: if isSignedIn() && (isTaskParticipant() || isOrgMember() || isSuperAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isTaskParticipant() || isSuperAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.createdBy || isSuperAdmin());
    }

    /**
     * @description Grant search agent configuration.
     * @path /grant_agent_config/{orgId}
     * @allow (read, write) Any signed-in user can manage agent configs.
     */
    match /grant_agent_config/{orgId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Suggested grants discovered by search agents.
     * @path /grant_suggestions/{grantId}
     * @allow (read, create) Any signed-in user can read and create grant suggestions.
     * @allow (update) Any signed-in user can update grant status (apply, approve, deny).
     * @allow (delete) Only super admin can delete grants.
     */
    match /grant_suggestions/{grantId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && request.auth.token.email == 'lucas@soltheory.com';
    }

    /**
     * @description CMS configuration for admin-managed content (news slideshow, etc.).
     * @path /cms_config/{configId}
     * @allow (read) Any signed-in user can read CMS config (to display content).
     * @allow (write) Only admins (lucas@soltheory.com, steve@soltheory.com) can modify.
     */
    match /cms_config/{configId} {
      function isCmsAdmin() {
        return request.auth.token.email == 'lucas@soltheory.com'
          || request.auth.token.email == 'steve@soltheory.com'
          || request.auth.token.email == 'gerard@soltheory.com';
      }
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && isCmsAdmin();
    }

    /**
     * @description Activity log for tracking user actions across the platform.
     * @path /activity_log/{eventId}
     * @allow (read) Signed-in users can read activity from their own org domain.
     * @allow (create) Any signed-in user can log activity events.
     * @deny (update, delete) Activity events are immutable.
     */
    match /activity_log/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description SMS opt-in submissions from the public website.
     * @path /sms_optins/{optinId}
     * @allow (create) Anyone can submit an SMS opt-in (public form, no auth required).
     * @allow (read) Only signed-in users (admins) can read opt-in data.
     * @deny (update, delete) Opt-in records are immutable from the client.
     */
    match /sms_optins/{optinId} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Timesheet entries for tracking team hours.
     * @path /timesheet_entries/{entryId}
     * @allow (read, create, update, delete) Any signed-in user can manage timesheet entries.
     */
    match /timesheet_entries/{entryId} {
      allow read, create, update, delete: if isSignedIn();
    }

    /**
     * @description Custom customers for timesheet categorization.
     * @path /timesheet_customers/{customerId}
     */
    match /timesheet_customers/{customerId} {
      allow read, create, update, delete: if isSignedIn();
    }

    /**
     * @description Custom services for timesheet categorization.
     * @path /timesheet_services/{serviceId}
     */
    match /timesheet_services/{serviceId} {
      allow read, create, update, delete: if isSignedIn();
    }

    /**
     * @description AI usage logs for tracking token consumption and costs.
     * @path /ai_usage/{usageId}
     * @allow (read) Any signed-in user can read usage data for platform-wide aggregation.
     * @allow (create) Any signed-in user or server can log usage events.
     * @deny (update, delete) Usage events are immutable.
     */
    match /ai_usage/{usageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
    