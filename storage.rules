rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read/write to their own folder
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // CMS content images (news slides, etc.) — admin write, authenticated read
    match /cms/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.token.email == 'lucas@soltheory.com'
         || request.auth.token.email == 'steve@soltheory.com');
    }

    // INSiGHT Walkthroughs (videos and thumbnails) — admin write, authenticated read
    match /walkthroughs/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.token.email == 'lucas@soltheory.com'
         || request.auth.token.email == 'steve@soltheory.com');
    }

    // Instagram media uploads (images and videos for campaigns)
    match /instagram_media/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Campaign email images (hero images, product photos, etc.)
    match /campaign_images/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
